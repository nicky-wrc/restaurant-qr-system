# PostgreSQL connection string (Prisma)
#
# แทนที่ DB_USER และ DB_PASSWORD ด้วยค่าจริงของ PostgreSQL บนเครื่องคุณ
# (อย่าปล่อยคำว่า USER หรือ PASSWORD ตรงๆ — มันคือตัวอย่างในเอกสารเท่านั้น)
#
# รูปแบบ: postgresql://DB_USER:DB_PASSWORD@HOST:PORT/DATABASE_NAME?schema=public
#
# ถ้ารหัสผ่านมีอักขระพิเศษ (@ # : / ? ฯลฯ) ต้องเข้ารหัสแบบ URL ก่อนใส่ในนี้
# เช่น @ → %40
#
DATABASE_URL="postgresql://postgres:YOUR_REAL_PASSWORD_HERE@localhost:5432/qr_menu?schema=public"

# Allowed origin for REST + Socket.io (Next.js dev server)
WEB_ORIGIN="http://localhost:3000"

PORT=4000

# JWT — ต้องยาวอย่างน้อย 16 ตัวอักษร (production ให้ใช้สุ่มจาก openssl rand -hex 32)
JWT_ACCESS_SECRET="change-me-access-secret-min-16-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-16-chars"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7
